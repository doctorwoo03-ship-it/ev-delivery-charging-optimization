# ── Kakao Map (required) ──────────────────────────────────────────────────────
# JavaScript SDK appkey — used in the browser to render the map
VITE_KAKAO_MAP_API_KEY=your_kakao_map_api_key_here

# ── Backend API base URL (required) ───────────────────────────────────────────
# Single base URL for all backend API calls (directions + chargers).
# Production: https://ev-delivery-charging-backend.onrender.com
# Local dev:  http://localhost:8000
VITE_API_BASE_URL=https://ev-delivery-charging-backend.onrender.com

# ── Debug logging (development only — never set in production) ────────────────
# VITE_MVP8_DEBUG=true

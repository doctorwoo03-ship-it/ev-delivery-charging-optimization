# ── Kakao Map (required) ──────────────────────────────────────────────────────
# JavaScript SDK appkey — used in the browser to render the map
VITE_KAKAO_MAP_API_KEY=your_kakao_map_api_key_here

# ── Backend proxy (required for production) ───────────────────────────────────
# Points to the deployed backend; proxies Kakao Directions and charger API calls
# Development default: http://localhost:8000
VITE_DIRECTIONS_API_BASE_URL=https://your-backend.example.com

# ── Charger API (optional — falls back to sample data if not set) ─────────────
# Same backend base URL if charger fetch also goes through the proxy
VITE_CHARGER_API_BASE_URL=https://your-backend.example.com

# ── Debug logging (development only — never set in production) ────────────────
# VITE_MVP8_DEBUG=true
